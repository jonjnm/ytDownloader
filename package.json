{
  "name": "ytdownloader",
  "version": "3.5.0",
  "description": "A GUI application to download videos and audio from YouTube and other platforms",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build",
    "build:linux": "electron-builder build --linux",
    "build:win": "electron-builder build --win",
    "build:mac": "electron-builder build --mac",
    "lint": "eslint src/",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "youtube",
    "downloader",
    "electron",
    "yt-dlp",
    "video",
    "audio"
  ],
  "author": {
    "name": "aandrew-me",
    "url": "https://github.com/aandrew-me"
  },
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aandrew-me/ytDownloader"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0"
  },
  "build": {
    "appId": "com.aandrew-me.ytdownloader",
    "productName": "ytDownloader",
    "copyright": "Copyright © 2024",
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "snap"
      ],
      "category": "Utility",
      "icon": "assets/icons"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "snap": {
      "publish": [
        "github"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  }
}
